# GCP Configuration
# Authentication uses Application Default Credentials (ADC)
# Run: gcloud auth application-default login
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# BigQuery Configuration
BQ_DATASET_RAW=raw_google_ads
BQ_DATASET_STAGING=staging_google_ads
BQ_DATASET_STAGING_TRENDS=staging_trends
BQ_DATASET_INTERMEDIATE=intermediate
BQ_DATASET_MARTS_MARKETING=marts_marketing
BQ_DATASET_MARTS_ANALYTICS=marts_analytics

# Cloud Storage Configuration
GCS_BUCKET_RAW_DATA=your-project-id-raw-data
GCS_BUCKET_PROCESSED=your-project-id-processed-data

# Data Extraction Configuration
USE_SYNTHETIC_DATA=true
DATA_START_DATE=2024-01-01
DATA_END_DATE=2024-12-31

# Google Ads API (for future real API use)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# External APIs (for future real API use)
OPENWEATHER_API_KEY=
